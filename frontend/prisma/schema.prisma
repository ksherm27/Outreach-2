generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model companies {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(500)
  domain         String?   @unique @db.VarChar(255)
  crunchbase_id  String?   @unique @db.VarChar(255)
  funding_stage  String?   @db.VarChar(50)
  total_raised   BigInt?
  employee_count Int?
  founded_year   Int?      @db.SmallInt
  hq_location    String?   @db.VarChar(255)
  description    String?
  is_saas        Boolean?
  is_public      Boolean   @default(false)
  industry       String?   @db.VarChar(255)
  enriched_at    DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)

  jobs     scraped_jobs[]
  contacts contacts[]
}

model contacts {
  id                 Int      @id @default(autoincrement())
  company_id         Int
  first_name         String?  @db.VarChar(255)
  last_name          String?  @db.VarChar(255)
  email              String   @db.VarChar(255)
  email_confidence   Float?
  title              String?  @db.VarChar(500)
  linkedin_url       String?  @db.VarChar(2048)
  phone              String?  @db.VarChar(50)
  source             String   @db.VarChar(50)
  hubspot_contact_id String?  @db.VarChar(255)
  is_suppressed      Boolean  @default(false)
  assigned_recruiter String?  @db.VarChar(255)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)

  company            companies          @relation(fields: [company_id], references: [id])
  outreach_messages  outreach_messages[]
  replies            replies[]

  @@unique([email, company_id], name: "uq_contact_email_company")
}

model scraped_jobs {
  id               Int       @id @default(autoincrement())
  source_url       String    @db.VarChar(2048)
  board_name       String    @db.VarChar(50)
  title            String    @db.VarChar(500)
  company_name     String    @db.VarChar(500)
  location         String?   @db.VarChar(500)
  description      String?
  posted_date      DateTime? @db.Date
  raw_data         Json?
  icp_score        Int?      @db.SmallInt
  gtm_category     String?   @db.VarChar(50)
  is_qualified     Boolean   @default(false)
  is_excluded      Boolean   @default(false)
  exclusion_reason String?   @db.VarChar(255)
  scrape_run_id    Int?
  company_id       Int?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  company           companies?          @relation(fields: [company_id], references: [id])
  scrape_run        scrape_runs?        @relation(fields: [scrape_run_id], references: [id])
  outreach_messages outreach_messages[]
}

model outreach_messages {
  id               Int       @id @default(autoincrement())
  contact_id       Int
  job_id           Int
  platform         String    @db.VarChar(20)
  campaign_id      String    @db.VarChar(255)
  platform_lead_id String?   @db.VarChar(255)
  status           String    @default("pending") @db.VarChar(20)
  variables        Json
  launched_at      DateTime? @db.Timestamptz(6)
  paused_at        DateTime? @db.Timestamptz(6)
  call_reminder_at DateTime? @db.Timestamptz(6)
  hubspot_deal_id  String?   @db.VarChar(255)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  contact contacts     @relation(fields: [contact_id], references: [id])
  job     scraped_jobs @relation(fields: [job_id], references: [id])
  replies replies[]
}

model replies {
  id                        Int       @id @default(autoincrement())
  outreach_message_id       Int?
  contact_id                Int
  platform                  String    @db.VarChar(20)
  platform_message_id       String    @unique @db.VarChar(255)
  subject                   String?   @db.VarChar(1000)
  body                      String
  received_at               DateTime  @db.Timestamptz(6)
  reply_type                String?   @db.VarChar(30)
  classification_confidence Float?
  classification_reasoning  String?
  ooo_return_date           DateTime? @db.Date
  action_taken              String?   @db.VarChar(50)
  action_taken_at           DateTime? @db.Timestamptz(6)
  assigned_recruiter        String?   @db.VarChar(255)
  created_at                DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                DateTime  @default(now()) @db.Timestamptz(6)

  outreach_message outreach_messages? @relation(fields: [outreach_message_id], references: [id])
  contact          contacts           @relation(fields: [contact_id], references: [id])
}

model scrape_runs {
  id             Int       @id @default(autoincrement())
  board_name     String    @db.VarChar(50)
  status         String    @default("running") @db.VarChar(20)
  jobs_found     Int       @default(0)
  jobs_new       Int       @default(0)
  jobs_duplicate Int       @default(0)
  error_message  String?
  started_at     DateTime  @db.Timestamptz(6)
  completed_at   DateTime? @db.Timestamptz(6)

  jobs scraped_jobs[]
}

model suppression_list {
  id              Int      @id @default(autoincrement())
  email           String   @unique @db.VarChar(255)
  reason          String   @db.VarChar(50)
  suppressed_at   DateTime @db.Timestamptz(6)
  source_reply_id Int?
}

model enrichment_cache {
  id         Int      @id @default(autoincrement())
  cache_key  String   @unique @db.VarChar(500)
  data_json  Json
  created_at DateTime @db.Timestamptz(6)
  expires_at DateTime @db.Timestamptz(6)
}

model recruiter_assignments {
  id                 Int       @id @default(autoincrement())
  recruiter_name     String    @db.VarChar(255)
  recruiter_slack_id String    @db.VarChar(50)
  is_active          Boolean   @default(true)
  last_assigned_at   DateTime? @db.Timestamptz(6)
  assignment_count   Int       @default(0)
}

model email_accounts {
  id               Int      @id @default(autoincrement())
  email_address    String   @unique @db.VarChar(255)
  display_name     String   @db.VarChar(255)
  platform         String   @db.VarChar(20)
  warmup_status    String   @default("pending") @db.VarChar(20)
  daily_send_limit Int      @default(30)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
}

model outreach_templates {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(255)
  subject        String?  @db.VarChar(1000)
  body           String
  stage_number   Int      @db.SmallInt
  stage_label    String?  @db.VarChar(50)
  platform       String   @db.VarChar(20)
  sequence_group String?  @db.VarChar(100)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@unique([sequence_group, stage_number, platform], name: "uq_template_sequence_stage_platform")
}

model users {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(255)
  email            String    @unique @db.VarChar(255)
  role             String    @default("recruiter") @db.VarChar(20)
  slack_id         String?   @db.VarChar(50)
  is_active        Boolean   @default(true)
  assignment_count Int       @default(0)
  last_assigned_at DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
}

model system_settings {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(100)
  value      String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}
